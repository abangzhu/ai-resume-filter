{
  "manifest_version": 3,
  "name": "CVFilterX",
  "version": "1.0.0",
  "description": "飞书招聘智能简历筛选助手",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.feishu.cn/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.feishu.cn/hire/*"],
      "js": ["content/api-inject.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.feishu.cn/hire/*"],
      "js": [
        "lib/constants.js",
        "lib/utils.js",
        "lib/messaging.js",
        "lib/storage.js",
        "content/extractor.js",
        "content/overlay.js",
        "content/template-dialog.js",
        "content/scoring.js",
        "content/paginator.js",
        "content/content.js"
      ],
      "css": ["lib/tokens.css", "content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/api-interceptor.js"],
      "matches": ["https://*.feishu.cn/*"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "128": "assets/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "128": "assets/icon128.png"
  }
}
